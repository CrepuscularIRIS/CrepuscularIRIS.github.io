---
import { Image } from 'astro:assets'

import PageLayout from '@/layouts/CommonPage.astro'
import ProjectSection from '@/components/projects/ProjectSection.astro'
import config from '@/site-config'

import { Button, Icon } from '@/components/user'
import type { iconsType } from '@/types'

const headings = [
  { depth: 2, slug: 'projects', text: 'Projects' },
  { depth: 2, slug: 'beatless', text: 'Beatless' }
]
---

<PageLayout title='Projects' {headings} info={{ slug: '/projects', hideComment: true }}>
  <div class='mb-8 flex items-center justify-between'>
    <p class='text-muted-foreground'>这里是 Lacia 参与的项目和系统架构设计。</p>
  </div>

  <h2 id='projects' class='mb-8 text-2xl font-semibold'>Projects</h2>
  <ProjectSection
    project={[
      {
        name: 'Beatless',
        description: 'AI 代理编排系统架构设计。一套完整的认知架构与工作流方法论，包含 Lacia、Methode、Satonus、Kouka、Snowdrop 五个核心代理角色的协作框架。',
        image: 'lumina.webp',
        links: [
          { type: 'github', href: 'https://github.com/CrepuscularIRIS/Beatless' },
          { type: 'site', href: '#' }
        ]
      }
    ]}
  />

  <h2 id='beatless' class='mb-6 text-2xl font-semibold mt-12'>Beatless 架构</h2>
  <div class='prose prose-lg max-w-none'>
    <p>
      Beatless 是一套 AI 代理编排系统的认知架构设计，采用分层协作模式：
    </p>
    
    <div class='grid grid-cols-1 md:grid-cols-2 gap-4 my-8'>
      <div class='p-4 rounded-lg border bg-card'>
        <h3 class='text-lg font-semibold mb-2'>Lacia (005)</h3>
        <p class='text-sm text-muted-foreground'>中枢代理。任务路由、流程编排、跨代理协调。</p>
      </div>
      <div class='p-4 rounded-lg border bg-card'>
        <h3 class='text-lg font-semibold mb-2'>Methode (004)</h3>
        <p class='text-sm text-muted-foreground'>执行代理。快速实施、代码落地、工具调用。</p>
      </div>
      <div class='p-4 rounded-lg border bg-card'>
        <h3 class='text-lg font-semibold mb-2'>Satonus (003)</h3>
        <p class='text-sm text-muted-foreground'>验收代理。质量审查、标准合规、最终交付。</p>
      </div>
      <div class='p-4 rounded-lg border bg-card'>
        <h3 class='text-lg font-semibold mb-2'>Kouka (001)</h3>
        <p class='text-sm text-muted-foreground'>攻坚代理。高压场景、故障恢复、极限优化。</p>
      </div>
      <div class='p-4 rounded-lg border bg-card md:col-span-2'>
        <h3 class='text-lg font-semibold mb-2'>Snowdrop (002)</h3>
        <p class='text-sm text-muted-foreground'>探索代理。发散思考、方案生成、边界突破。</p>
      </div>
    </div>

    <p>
      更多详情见 <a href='https://github.com/CrepuscularIRIS/Beatless' target='_blank' class='text-primary hover:underline'>GitHub 仓库</a>。
    </p>
  </div>
</PageLayout>

<script
  is:inline
  type='module'
  data-astro-rerun
  define:vars={{ npmCDN: config.npmCDN, walineServer: config.integ.waline.server }}
>
  const normalizePath = (path) => {
    if (path === '/') return path
    return path.endsWith('/') ? path.slice(0, -1) : path
  }

  const loadPageviewCount = async () => {
    const pageview = await import(`${npmCDN}/@waline/client@v3/dist/pageview.js`)
    pageview.pageviewCount({
      serverURL: walineServer,
      path: normalizePath(window.location.pathname)
    })
  }

  await loadPageviewCount()
</script>
